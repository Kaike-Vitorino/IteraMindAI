# Copy to .env and fill in the providers you want to use.
# The app runs out of the box with the keyless "mock" provider, so all of
# these are optional.

# Google Gemini
GOOGLE_GEMINI_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenRouter (gateway to many models)
OPENROUTER_API_KEY=

# Groq (fast inference)
GROQ_API_KEY=

# ---- Server tuning (optional) ----
# HOST=0.0.0.0
# PORT=7860
# MAX_ITERATIONS=8
# MAX_TOKENS=1024
# REQUEST_TIMEOUT=60
# CORS_ORIGINS=*
